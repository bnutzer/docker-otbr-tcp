#!/command/with-contenv bash

set -eu

if [[ "$RCP_USE_TCP" == "0" ]] ; then
	exit 0
fi

timeout=120
elapsed=0
while [[ $elapsed -lt $timeout ]]; do
  if [[ -e "$RCP_TTY" ]] && [[ -r "$RCP_TTY" ]]; then
    exit 0
  fi
  sleep 1
  elapsed=$((elapsed + 1))
done
echo "socat-ready: TTY $RCP_TTY NOT ready after ${timeout}s" >&2
exit 1
